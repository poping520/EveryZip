LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US

STRINGTABLE
{
    // Menu bar
    IDS_MENU_FILE,          "&File"
    IDS_MENU_SETTINGS,      "&Settings"
    IDS_MENU_HELP,          "&Help"
