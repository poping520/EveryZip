    IDS_TRAY_EXIT,          "Exit"
    // ListView columns
    IDS_COL_NAME,           "Name"
    IDS_COL_ARCHIVE,        "Archive File"
    IDS_COL_PATH,           "Internal Path"
    IDS_COL_COMPRESSED_SIZE,"Compressed Size"
    IDS_COL_ORIGINAL_SIZE,  "Original Size"
    IDS_COL_MODIFIED_TIME,  "Modified Time"
    // Sort arrows
    IDS_SORT_ASC,           " \x25B2"
    IDS_SORT_DESC,          " \x25BC"
    // Status bar
    IDS_STATUS_PROCESSING,  "Processing"
    IDS_STATUS_READY,       "Ready"
    IDS_STATUS_FILE_COUNT,  "Files"
    IDS_STATUS_ARCHIVE_COUNT,"Archives"
    // Dialogs
